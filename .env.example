# Database Connection
# Set these environment variables before running the scripts
# Copy this file to .env and fill in your actual values

PGHOST=localhost
PGPORT=5432
PGDATABASE=kakinoki_db
PGUSER=your_db_user
PGPASSWORD=your_db_password

# Paths (optional, adjust if non-standard installation)
CLIP_DB_ROOT=/home/irsl/workspace/CLIP_DB
RBTE_DOCKER_ROOT=/home/irsl/workspace/rbte_docker
SKETCHSCAPE_ROOT=/home/irsl/workspace/SketchScape
SBIR_MODEL_PATH=/home/irsl/workspace/SketchScape/models/fscoco_normal.pth

# SBIR Parameters (optional)
SBIR_TOPK=5
SBIR_DEVICE=auto
SBIR_GALLERY_SOURCE_TYPE=photo
SBIR_DISPLAY_SOURCE_TYPE=photo
SBIR_SCHEMA=home_robot
SBIR_TABLE=sketch_images
